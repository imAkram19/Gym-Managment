# Supabase Connection Settings
# Copy these values from your Gym Management frontend .env file
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ZKTeco K40 Fingerprint Device Settings
ZK_DEVICE_IP=192.168.1.201
ZK_DEVICE_PORT=4370

# Simulation Configuration
# Set to true to run in simulation mode (essential for remote development in Bangalore)
# Set to false in Hyderabad production environment
ZK_SIMULATE=true
SIMULATOR_PORT=4371
